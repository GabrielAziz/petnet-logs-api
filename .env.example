# Banco de dados
DB_HOST=db
DB_NAME=petnet_logs
DB_USER=
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Token de autenticação da API
LOG_API_TOKEN=

# Traefik — domínio exposto na VPS (ex: logs-api.seudominio.com.br)
LOGS_API_HOST=

# Porta exposta no host para o Traefik (host network) — não pode conflitar com outros serviços
APP_PORT=8081